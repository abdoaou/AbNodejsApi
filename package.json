{
  "name": "hostinger-ecommerce-api",
  "version": "1.0.0",
  "description": "Production-ready multi-website ecommerce REST API (Express + Supabase/PostgreSQL or MySQL)",
  "main": "server.js",
  "scripts": {
    "build": "node -e \"console.log('Build complete (Express API — no compile step)')\"",
    "start": "node server.js",
    "dev": "node --watch server.js",
    "verify:env": "node scripts/verify-env.js",
    "verify:db": "node scripts/test-db.js",
    "test:parent-categories": "node scripts/test-parent-categories.js",
    "diagnose": "node scripts/diagnose.js"
  },
  "engines": {
    "node": "18.x || 20.x || 22.x || 24.x"
  },
  "keywords": [
    "express",
    "mysql",
    "ecommerce",
    "rest-api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "@supabase/supabase-js": "^2.47.10",
    "mysql2": "^3.11.4",
    "pg": "^8.13.1"
  }
}
