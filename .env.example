NODE_ENV=development
PORT=3000

JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d

# --- Supabase (recommended) ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Hostinger docs often use this name — same value as publishable/anon key:
# SUPABASE_ANON_KEY=sb_publishable_xxx
# Server-only: bypass RLS for admin API (Settings → API → service_role)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# Option A: full Postgres URI (Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Option B: password only (app builds the URI from SUPABASE_PROJECT_REF)
# SUPABASE_DB_PASSWORD=your-database-password

# --- Local MySQL (only if DATABASE_URL is empty) ---
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=ecommerce
# DB_PORT=3306

DB_CONNECTION_LIMIT=10
DB_SSL=true

CORS_ORIGIN=*
RATE_LIMIT_MAX=300
